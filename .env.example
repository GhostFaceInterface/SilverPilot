SILVERPILOT_RUNTIME_REFERENCE_REFRESH_INTERVAL_SECONDS=1800
SILVERPILOT_RUNTIME_REFERENCE_MAX_DATA_AGE_SECONDS=21600
SILVERPILOT_RUNTIME_WARMUP_BARS=201
