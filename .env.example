# Application
APP_ENV=local
APP_NAME=SilverPilot
APP_DEBUG=true
INITIAL_BALANCE_USD=600
REAL_MONEY_ENABLED=false

# Database
POSTGRES_DB=silverpilot
POSTGRES_USER=silverpilot
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql+psycopg://silverpilot:change_me@postgres:5432/silverpilot

# Risk policy placeholders; exact values are set after data collection starts.
MAX_DAILY_LOSS_USD=
MAX_WEEKLY_LOSS_USD=
MAX_SPREAD_PERCENT=

# LLM providers are disabled in Phase 0.
OPENROUTER_API_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=

# LLM budget placeholders; enforced after the LLM gateway exists.
NEWS_AGENT_DAILY_BUDGET_USD=0.20
REPORT_AGENT_DAILY_BUDGET_USD=0.10
RISK_AGENT_DAILY_BUDGET_USD=0.30
AUDIT_AGENT_WEEKLY_BUDGET_USD=1.00
