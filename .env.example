# Application
APP_ENV=local
APP_NAME=SilverPilot
APP_DEBUG=true
INITIAL_BALANCE_USD=600
REAL_MONEY_ENABLED=false

# Database
POSTGRES_DB=silverpilot
POSTGRES_USER=silverpilot
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql+psycopg://silverpilot:change_me@postgres:5432/silverpilot

# Risk policy. Phase 4 starts with deterministic paper-trade blocks only.
RISK_DATA_STALE_AFTER_MINUTES=60
RISK_MAX_SPREAD_PERCENT=5.0
RISK_MAX_24H_VOLATILITY_PERCENT=12.0
RISK_MAX_7D_VOLATILITY_PERCENT=25.0
RISK_FOMO_LOOKBACK_MINUTES=180
RISK_FOMO_RISE_PERCENT=6.0
RISK_MAX_DAILY_LOSS_USD=30.0
RISK_MAX_WEEKLY_LOSS_USD=60.0
RISK_MIN_EXPECTED_NET_GAIN_PERCENT=0.0

# Collector runner placeholders.
COLLECTOR_INTERVAL_SECONDS=900
COLLECTOR_JOB=kuveyt-silver
COLLECTOR_JOBS=kuveyt-silver,global-xag-usd,tcmb-usd-try,fed-rss,fred-macro
COLLECTOR_USER_AGENT=SilverPilot/0.1 public-source paper-trading collector
KUVEYT_SILVER_URL=https://www.kuveytturk.com.tr/kendim-icin/yatirim-urunleri/hazine-urunleri/canli-gumus-fiyatlari-ve-gram-gumus-hesaplama
GLOBAL_XAG_SOURCE_PRIORITY=stooq,gold-api,metals-dev
GLOBAL_XAG_FRESHNESS_MINUTES=90
STOOQ_XAG_USD_URL=https://stooq.com/q/l/?s=xagusd&f=sd2t2ohlcv&h&e=csv
STOOQ_XAG_USD_TIMEOUT_SECONDS=10
STOOQ_XAG_USD_RETRIES=2
STOOQ_XAG_USD_BACKOFF_SECONDS=1
GOLD_API_XAG_USD_ENABLED=true
GOLD_API_XAG_USD_URL=https://api.gold-api.com/price/XAG
GOLD_API_XAG_USD_TIMEOUT_SECONDS=10
METALS_DEV_API_KEY=
METALS_DEV_SPOT_URL=https://api.metals.dev/v1/metal/spot
METALS_DEV_TIMEOUT_SECONDS=10
TCMB_TODAY_XML_URL=https://www.tcmb.gov.tr/kurlar/today.xml
FED_RSS_ENABLED=true
FED_RSS_URL=https://www.federalreserve.gov/feeds/press_monetary.xml
MANUAL_PRICE_SOURCE_TYPE=bank
MANUAL_PRICE_SOURCE=manual-scheduled
MANUAL_PRICE_ASSET_SYMBOL=XAG
MANUAL_PRICE_BUY_PRICE=10.00
MANUAL_PRICE_SELL_PRICE=9.80
MANUAL_PRICE_CURRENCY=USD
BLS_API_KEY=
FRED_API_KEY=
FRED_API_BASE_URL=https://api.stlouisfed.org/fred
FRED_SERIES_IDS=CPIAUCSL,PPIACO,UNRATE,FEDFUNDS,DGS10,DTWEXBGS

# LLM providers are disabled until the LLM gateway phase.
OPENROUTER_API_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=

# LLM budget placeholders; enforced after the LLM gateway exists.
NEWS_AGENT_DAILY_BUDGET_USD=0.20
REPORT_AGENT_DAILY_BUDGET_USD=0.10
RISK_AGENT_DAILY_BUDGET_USD=0.30
AUDIT_AGENT_WEEKLY_BUDGET_USD=1.00
