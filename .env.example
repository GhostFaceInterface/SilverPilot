SILVERPILOT_APP_NAME=SilverPilot
SILVERPILOT_ENVIRONMENT=development
SILVERPILOT_DATABASE_URL=postgresql+psycopg://silverpilot:change-me@postgres:5432/silverpilot
SILVERPILOT_LOG_LEVEL=INFO
SILVERPILOT_API_PORT=8000
SILVERPILOT_POSTGRES_PORT=5432

POSTGRES_DB=silverpilot
POSTGRES_USER=silverpilot
POSTGRES_PASSWORD=change-me

SILVERPILOT_TELEGRAM_ENABLED=false
SILVERPILOT_TELEGRAM_BOT_TOKEN=
SILVERPILOT_TELEGRAM_DEFAULT_CHAT_ID=
SILVERPILOT_TELEGRAM_API_BASE_URL=https://api.telegram.org
SILVERPILOT_DEPLOYED_SHA=

SILVERPILOT_RUNTIME_ENABLED=false
SILVERPILOT_RUNTIME_ACCOUNT_ID=
SILVERPILOT_RUNTIME_BANK_INSTRUMENT_ID=
SILVERPILOT_RUNTIME_EXECUTION_INSTRUMENT_ID=
SILVERPILOT_RUNTIME_REFERENCE_INSTRUMENT_ID=
SILVERPILOT_RUNTIME_STRATEGY_ID=
SILVERPILOT_RUNTIME_REFERENCE_SOURCE=
SILVERPILOT_RUNTIME_FX_SOURCE=
SILVERPILOT_RUNTIME_FX_PAIR=USDTRY
SILVERPILOT_RUNTIME_REFERENCE_TIMEFRAME=4h
SILVERPILOT_INDICATOR_SOURCE_POLICY=reference_market_first
SILVERPILOT_EXECUTION_SOURCE_POLICY=account_bound_bank_quote
SILVERPILOT_REFERENCE_DELAY_POLICY=provider_delayed
SILVERPILOT_REFERENCE_INGESTION_DELAY_SECONDS=60
SILVERPILOT_EXECUTION_QUOTE_SELECTION_POLICY=latest_before_or_at_decision
SILVERPILOT_MAX_QUOTE_LAG_SECONDS=300
SILVERPILOT_RUNTIME_COLLECT_INTERVAL_SECONDS=300
SILVERPILOT_RUNTIME_BAR_TIMEFRAME=5m
